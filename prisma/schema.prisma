generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  users     User[]
  roles     Role[]
  invites   UserInvite[]
  auditLogs AuditLog[]

  categories        Category[]
  vendors           Vendor[]
  suppliers         Supplier[]
  apparels          Apparel[]
  stockMovements     StockMovement[]
  events             Event[]
  eventReservations  EventReservation[]
  laundryOrders      LaundryOrder[]
  purchaseOrders     PurchaseOrder[]

  // Master Data
  movementTypes      MovementType[]
  reasonCodes        ReasonCode[]
  stockConditions    StockConditionMaster[]
  unitsOfMeasure     UnitOfMeasure[]
  locations          Location[]
  documentNumberings DocumentNumbering[]
  inventorySettings  InventorySettings?

  // Dashboard / Analytics
  dashboardSnapshots  DashboardSnapshot[]
  kpiTrendSnapshots   KPITrendSnapshot[]
  aiRecommendations   AIRecommendation[]

  // Vendor Billing & Financial
  laundryVendorRates         LaundryVendorRate[]
  laundryVendorInvoices      LaundryVendorInvoice[]
  laundryBillingSources      LaundryBillingSource[]
  vendorLiabilities          VendorLiability[]
  vendorLiabilityCredits     VendorLiabilityCredit[]
  vendorPayments             VendorPayment[]
  vendorLedgerEntries        VendorLedger[]

  @@map("tenants")
}

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @db.Uuid
  fullName     String
  email        String
  passwordHash String?
  status       String   @default("PENDING")

  mfaEnabled       Boolean @default(false)
  mfaSecret        String?
  mfaSetupRequired Boolean @default(false)

  isActive Boolean @default(true)
  isLocked Boolean @default(false)

  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  createdBy   String?   @db.Uuid
  updatedAt   DateTime  @updatedAt
  updatedBy   String?   @db.Uuid

  tenant Tenant @relation(fields: [tenantId], references: [id])

  passwordResetTokens PasswordResetToken[]
  refreshTokens       RefreshToken[]
  userRoles           UserRole[]
  mfaBackupCodes      MfaBackupCode[]

  auditLogsInitiated AuditLog[] @relation("AuditActor")
  auditLogsReceived  AuditLog[] @relation("AuditTarget")

  securityAlerts SecurityAlert[]
  invites        UserInvite[]

  @@unique([tenantId, email])
  @@map("users")
}

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  name        String
  description String?
  isSystem    Boolean  @default(false)
  requiresMfa Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([tenantId, name])
  @@map("roles")
}

model UserRole {
  userId     String   @db.Uuid
  roleId     String   @db.Uuid
  assignedAt DateTime @default(now())
  assignedBy String?  @db.Uuid

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model Permission {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String  @unique
  description String?

  rolePermissions   RolePermission[]
  modulePermissions PlatformModulePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @db.Uuid
  permissionId String @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([tokenHash])
  @@map("password_reset_tokens")
}

model PasswordResetRequest {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email       String
  ipAddress   String
  requestedAt DateTime @default(now())

  @@index([email, requestedAt])
  @@index([ipAddress, requestedAt])
  @@map("password_reset_requests")
}

model MfaBackupCode {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  codeHash  String
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("mfa_backup_codes")
}

model RefreshToken {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String  @db.Uuid
  tokenHash   String
  mfaVerified Boolean @default(false)

  deviceInfo   String?
  ipAddress    String?
  lastActiveAt DateTime?

  expiresAt       DateTime
  revokedAt       DateTime?
  revokedByIp     String?
  replacedByToken String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([tokenHash])
  @@map("refresh_tokens")
}

model AuditLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @db.Uuid
  actorUserId  String?  @db.Uuid
  targetUserId String?  @db.Uuid

  action    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  actor  User? @relation("AuditActor", fields: [actorUserId], references: [id])
  target User? @relation("AuditTarget", fields: [targetUserId], references: [id])

  @@index([tenantId])
  @@index([actorUserId])
  @@index([targetUserId])
  @@index([action])
  @@map("audit_logs")
}

model SecurityAlert {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  type      String
  title     String
  message   String
  severity  String
  metadata  String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@map("security_alerts")
}

model UserInvite {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  email     String
  tokenHash String
  expiresAt DateTime
  createdBy String   @db.Uuid
  usedAt    DateTime?
  createdAt DateTime @default(now())

  tenant  Tenant @relation(fields: [tenantId], references: [id])
  creator User   @relation(fields: [createdBy], references: [id])

  @@index([tokenHash])
  @@index([tenantId, email])
  @@map("user_invites")
}

model Category {
  id        Int      @id @default(autoincrement())
  tenantId  String   @db.Uuid
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  apparels Apparel[]

  @@unique([tenantId, name])
}

model Vendor {
  id           Int      @id @default(autoincrement())
  tenantId     String   @db.Uuid
  name         String
  contactInfo  String?
  taxId        String?
  paymentTerms String?
  creditLimit  Decimal? @db.Decimal(12, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  laundryOrders LaundryOrder[]

  laundryVendorRates    LaundryVendorRate[]
  laundryVendorInvoices LaundryVendorInvoice[]
  vendorLiabilities     VendorLiability[]
  vendorPayments        VendorPayment[]
  vendorLedgerEntries   VendorLedger[]

  @@unique([tenantId, name])
}

model Apparel {
  id            Int      @id @default(autoincrement())
  tenantId      String   @db.Uuid
  categoryId    Int
  name          String
  unit          String
  minStockLevel Int      @default(0)
  unitValue     Decimal  @default(0) @db.Decimal(10, 2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  stockMovements     StockMovement[]
  eventReservations  EventReservation[]
  laundryOrderItems  LaundryOrderItem[]
  purchaseOrderItems PurchaseOrderItem[]

  laundryVendorRates        LaundryVendorRate[]
  laundryVendorInvoiceItems LaundryVendorInvoiceItem[]
  vendorLiabilities         VendorLiability[]

  @@unique([tenantId, name])
}

model StockMovement {
  id                   Int            @id @default(autoincrement())
  tenantId             String         @db.Uuid
  apparelId            Int
  movementType         String
  quantityChange       Int
  referenceType        String?
  referenceId          Int?
  reason               String?
  condition            StockCondition @default(CLEAN)
  recoveryOfMovementId Int?
  lossResponsibility   String?
  createdAt            DateTime       @default(now())
  createdBy            Int

  tenant     Tenant          @relation(fields: [tenantId], references: [id])
  apparel    Apparel         @relation(fields: [apparelId], references: [id])
  recoveryOf StockMovement?  @relation("RecoveryLink", fields: [recoveryOfMovementId], references: [id])
  recoveries StockMovement[] @relation("RecoveryLink")

  billingSource   LaundryBillingSource?
  vendorLiability VendorLiability?

  @@index([apparelId, createdAt])
  @@index([tenantId])
  @@index([tenantId, movementType])
}

model Event {
  id        Int      @id @default(autoincrement())
  tenantId  String   @db.Uuid
  name      String
  eventDate DateTime
  status    String   @default("DRAFT")
  createdAt DateTime @default(now())

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  eventReservations EventReservation[]
}

model EventReservation {
  id          Int      @id @default(autoincrement())
  tenantId    String   @db.Uuid
  eventId     Int
  apparelId   Int
  reservedQty Int
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  createdBy   Int

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  event   Event   @relation(fields: [eventId], references: [id])
  apparel Apparel @relation(fields: [apparelId], references: [id])

  @@index([apparelId, status])
  @@index([tenantId])
}

model LaundryOrder {
  id                 Int       @id @default(autoincrement())
  tenantId           String    @db.Uuid
  vendorId           Int
  dispatchDate       DateTime  @default(now())
  expectedReturnDate DateTime?
  status             String    @default("DISPATCHED")
  createdAt          DateTime  @default(now())
  createdBy          Int

  tenant Tenant @relation(fields: [tenantId], references: [id])
  vendor Vendor @relation(fields: [vendorId], references: [id])

  items LaundryOrderItem[]

  @@index([tenantId, status])
}

model LaundryOrderItem {
  id             Int @id @default(autoincrement())
  laundryOrderId Int
  apparelId      Int
  qtyDispatched  Int
  qtyReturned    Int @default(0)
  qtyDamaged     Int @default(0)
  qtyMissing     Int @default(0)

  laundryOrder LaundryOrder @relation(fields: [laundryOrderId], references: [id])
  apparel      Apparel      @relation(fields: [apparelId], references: [id])
}

// Kept as an enum for the ledger backwards capability, but a model for DB logic
// See StockCondition model below
enum StockCondition {
  CLEAN
  DIRTY
}

// -------------------------------------------------------------------------------- //
// MASTER DATA
// -------------------------------------------------------------------------------- //

model MovementType {
  id                 Int      @id @default(autoincrement())
  tenantId           String   @db.Uuid
  code               String
  direction          String
  affectsClean       Boolean  @default(false)
  affectsDirty       Boolean  @default(false)
  isRecoveryType     Boolean  @default(false)
  isSystemControlled Boolean  @default(false)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
}

model ReasonCode {
  id               Int      @id @default(autoincrement())
  tenantId         String   @db.Uuid
  code             String
  description      String
  appliesTo        String
  requiresApproval Boolean  @default(false)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
}

model StockConditionMaster {
  id          Int      @id @default(autoincrement())
  tenantId    String   @db.Uuid
  code        String
  description String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
}

model UnitOfMeasure {
  id               Int      @id @default(autoincrement())
  tenantId         String   @db.Uuid
  code             String
  description      String
  conversionFactor Decimal  @default(1.0) @db.Decimal(10, 4)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
}

model Location {
  id        Int      @id @default(autoincrement())
  tenantId  String   @db.Uuid
  name      String
  type      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
}

model DocumentNumbering {
  id              Int      @id @default(autoincrement())
  tenantId        String   @db.Uuid
  entityType      String
  prefix          String
  currentSequence Int      @default(0)
  resetYearly     Boolean  @default(false)
  lastResetYear   Int?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, entityType])
}

model InventorySettings {
  id                         Int      @id @default(autoincrement())
  tenantId                   String   @unique @db.Uuid
  allowNegativeStock         Boolean  @default(false)
  requireApprovalForRecovery Boolean  @default(true)
  defaultLaundrySLA          Int      @default(7)
  enableMultiLocation        Boolean  @default(false)
  enableValuation            Boolean  @default(false)
  currencySymbol             String   @default("$") @db.VarChar(5)
  defaultTaxRate             Decimal  @default(0) @db.Decimal(5, 2)
  updatedAt                  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model Supplier {
  id           Int      @id @default(autoincrement())
  tenantId     String   @db.Uuid
  name         String
  contactInfo  String?
  taxId        String?
  paymentTerms String?
  creditLimit  Decimal? @db.Decimal(12, 2)
  isPreferred  Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  purchaseOrders PurchaseOrder[]

  @@unique([tenantId, name])
}

model PurchaseOrder {
  id           Int       @id @default(autoincrement())
  tenantId     String    @db.Uuid
  supplierId   Int
  poNumber     String
  status       String    @default("DRAFT")
  orderDate    DateTime?
  expectedDate DateTime?
  notes        String?
  createdBy    Int
  approvedBy   Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant   Tenant              @relation(fields: [tenantId], references: [id])
  supplier Supplier            @relation(fields: [supplierId], references: [id])
  items    PurchaseOrderItem[]

  @@unique([tenantId, poNumber])
  @@index([tenantId, status])
}

model PurchaseOrderItem {
  id              Int      @id @default(autoincrement())
  purchaseOrderId Int
  apparelId       Int
  orderedQty      Int
  receivedQty     Int      @default(0)
  unitCost        Decimal? @db.Decimal(10, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  apparel       Apparel       @relation(fields: [apparelId], references: [id])

  @@unique([purchaseOrderId, apparelId])
}

// -------------------------------------------------------------------------------- //
// DASHBOARD SNAPSHOTS
// -------------------------------------------------------------------------------- //

/// Nightly rollup of all executive KPIs per tenant.
/// Populated by DashboardSnapshotJob. Dashboard API reads exclusively from this table.
model DashboardSnapshot {
  id           String   @id @default(cuid())
  tenantId     String   @db.Uuid

  snapshotDate DateTime @db.Date

  // ─── Inventory Summary ───────────────────────────────────────────────────────
  totalPhysicalInventory Decimal? @db.Decimal(14, 2)
  availableInventory     Decimal? @db.Decimal(14, 2)
  reservedInventory      Decimal? @db.Decimal(14, 2)
  dirtyInventory         Decimal? @db.Decimal(14, 2)
  inLaundryInventory     Decimal? @db.Decimal(14, 2)

  // ─── Inventory Health Score (0-100) ──────────────────────────────────────────
  inventoryHealth        Decimal? @db.Decimal(5, 2)
  availabilityScore      Decimal? @db.Decimal(5, 2)
  stockoutRiskScore      Decimal? @db.Decimal(5, 2)
  dirtyRatioScore        Decimal? @db.Decimal(5, 2)
  lossRatioScore         Decimal? @db.Decimal(5, 2)
  agingScore             Decimal? @db.Decimal(5, 2)

  // ─── Demand Forecast (placeholders) ──────────────────────────────────────────
  predictedDemand30Days       Decimal? @db.Decimal(14, 2)
  forecastAccuracy            Decimal? @db.Decimal(5, 2)
  predictedPurchaseRequirement Decimal? @db.Decimal(14, 2)
  stockoutRisk                String?  // LOW | MEDIUM | HIGH

  // ─── Event KPIs ──────────────────────────────────────────────────────────────
  upcomingEvents              Int?
  eventsThisMonth             Int?
  eventCompletionRate         Decimal? @db.Decimal(5, 2)
  eventsPendingReconciliation Int?

  // ─── Loss & Recovery ─────────────────────────────────────────────────────────
  grossLoss       Decimal? @db.Decimal(14, 2)
  recovered       Decimal? @db.Decimal(14, 2)
  netLoss         Decimal? @db.Decimal(14, 2)
  lossRate        Decimal? @db.Decimal(7, 4)
  recoveryRate    Decimal? @db.Decimal(5, 2)
  financialImpact Decimal? @db.Decimal(14, 2)

  // ─── Vendor KPIs ─────────────────────────────────────────────────────────────
  vendorScore          Decimal? @db.Decimal(5, 2)
  highRiskVendorCount  Int?
  averageTurnaroundDays Decimal? @db.Decimal(6, 2)
  vendorLiability      Decimal? @db.Decimal(14, 2)

  // ─── Laundry KPIs ────────────────────────────────────────────────────────────
  dirtyStock           Decimal? @db.Decimal(14, 2)
  inLaundry            Decimal? @db.Decimal(14, 2)
  laundryAging0to3     Int?
  laundryAging4to7     Int?
  laundryAgingOver7    Int?
  avgLaundryCycleDays  Decimal? @db.Decimal(6, 2)
  delayedLaundryOrders Int?

  // ─── Risk Indicators ─────────────────────────────────────────────────────────
  stockoutRiskLevel        String? // LOW | MEDIUM | HIGH
  vendorRiskLevel          String? // LOW | MEDIUM | HIGH
  laundryBottleneckLevel   String? // LOW | MEDIUM | HIGH
  eventCapacityRiskLevel   String? // LOW | MEDIUM | HIGH

  // ─── Financial KPIs (placeholders) ───────────────────────────────────────────
  inventoryValue          Decimal? @db.Decimal(14, 2)
  monthlyConsumptionValue Decimal? @db.Decimal(14, 2)
  costOfLosses            Decimal? @db.Decimal(14, 2)
  costOfDamages           Decimal? @db.Decimal(14, 2)
  recoverySavings         Decimal? @db.Decimal(14, 2)

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, snapshotDate])
  @@index([tenantId, snapshotDate])
}

/// Daily time-series KPI values for trend charts.
/// One row per tenant per metric per day.
model KPITrendSnapshot {
  id           String   @id @default(cuid())
  tenantId     String   @db.Uuid

  snapshotDate DateTime @db.Date

  metricCode  String
  metricValue Decimal  @db.Decimal(14, 4)

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, metricCode, snapshotDate])
  @@index([tenantId, metricCode, snapshotDate])
}

/// AI-generated actionable recommendations for each tenant.
/// Populated externally or by an AI inference job.
model AIRecommendation {
  id          String   @id @default(cuid())
  tenantId    String   @db.Uuid

  priority    String
  type        String

  title       String
  description String

  payload     Json?

  status      String   @default("ACTIVE")

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, priority, createdAt])
}

// -------------------------------------------------------------------------------- //
// VENDOR BILLING & FINANCIAL
// -------------------------------------------------------------------------------- //

/// Vendor-specific washing rate contracts per apparel.
/// Multiple rate revisions allowed; only one active rate per vendor/apparel per period.
model LaundryVendorRate {
  id              Int       @id @default(autoincrement())
  tenantId        String    @db.Uuid
  vendorId        Int
  apparelId       Int

  washingRate     Decimal   @db.Decimal(12, 2)
  ironingRate     Decimal?  @db.Decimal(12, 2)
  dryCleaningRate Decimal?  @db.Decimal(12, 2)

  effectiveFrom   DateTime
  effectiveTo     DateTime?

  isActive        Boolean   @default(true)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  vendor  Vendor  @relation(fields: [vendorId], references: [id])
  apparel Apparel @relation(fields: [apparelId], references: [id])

  @@index([tenantId, vendorId])
  @@index([tenantId, apparelId])
  @@index([tenantId, vendorId, apparelId, effectiveFrom])
}

/// Vendor invoices generated from laundry return movements.
model LaundryVendorInvoice {
  id          Int       @id @default(autoincrement())
  tenantId    String    @db.Uuid
  invoiceNo   String
  vendorId    Int

  fromDate    DateTime
  toDate      DateTime
  invoiceDate DateTime

  subtotal    Decimal   @db.Decimal(12, 2)
  taxRate     Decimal   @default(0) @db.Decimal(5, 2)
  taxAmount   Decimal   @db.Decimal(12, 2)
  totalAmount Decimal   @db.Decimal(12, 2)
  paidAmount  Decimal   @default(0) @db.Decimal(12, 2)

  status      String    @default("DRAFT") // DRAFT | POSTED | PARTIALLY_PAID | PAID | CANCELLED
  remarks     String?

  createdBy   Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  vendor  Vendor  @relation(fields: [vendorId], references: [id])

  items              LaundryVendorInvoiceItem[]
  billingSources     LaundryBillingSource[]
  paymentAllocations VendorPaymentAllocation[]

  @@unique([tenantId, invoiceNo])
  @@index([tenantId, vendorId])
  @@index([tenantId, status])
}

/// Immutable invoice line items. Locked after invoice is posted.
model LaundryVendorInvoiceItem {
  id        Int     @id @default(autoincrement())
  invoiceId Int
  apparelId Int

  quantity  Decimal @db.Decimal(12, 2)
  rate      Decimal @db.Decimal(12, 2)
  amount    Decimal @db.Decimal(12, 2)

  remarks   String?

  invoice LaundryVendorInvoice @relation(fields: [invoiceId], references: [id])
  apparel Apparel              @relation(fields: [apparelId], references: [id])

  @@index([invoiceId])
}

/// Links stock movements to invoices to prevent duplicate billing.
/// Each movement can only be billed once.
model LaundryBillingSource {
  id              Int      @id @default(autoincrement())
  tenantId        String   @db.Uuid
  invoiceId       Int
  stockMovementId Int      @unique  // Prevent double-billing
  quantity        Decimal  @db.Decimal(12, 2)
  createdAt       DateTime @default(now())

  tenant        Tenant               @relation(fields: [tenantId], references: [id])
  invoice       LaundryVendorInvoice @relation(fields: [invoiceId], references: [id])
  stockMovement StockMovement        @relation(fields: [stockMovementId], references: [id])

  @@index([tenantId, invoiceId])
}

/// Loss/damage liability charged to vendor when lossResponsibility = LAUNDRY_VENDOR.
model VendorLiability {
  id               Int      @id @default(autoincrement())
  tenantId         String   @db.Uuid
  vendorId         Int
  stockMovementId  Int      @unique
  movementTypeCode String
  apparelId        Int

  quantity         Decimal  @db.Decimal(12, 2)
  unitCost         Decimal  @db.Decimal(12, 2)
  amount           Decimal  @db.Decimal(12, 2)
  settledAmount    Decimal  @default(0) @db.Decimal(12, 2)

  status           String   @default("OPEN") // OPEN | PARTIALLY_SETTLED | SETTLED | WAIVED | CREDITED
  remarks          String?

  createdAt        DateTime @default(now())

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  vendor        Vendor        @relation(fields: [vendorId], references: [id])
  stockMovement StockMovement @relation(fields: [stockMovementId], references: [id])
  apparel       Apparel       @relation(fields: [apparelId], references: [id])

  credits VendorLiabilityCredit[]

  @@index([tenantId, vendorId])
  @@index([tenantId, status])
}

/// Recovery credit applied against a vendor liability when lost items are found.
model VendorLiabilityCredit {
  id                  Int      @id @default(autoincrement())
  tenantId            String   @db.Uuid
  vendorLiabilityId   Int
  recoveryMovementId  Int

  quantity            Decimal  @db.Decimal(12, 2)
  unitCost            Decimal  @db.Decimal(12, 2)
  amount              Decimal  @db.Decimal(12, 2)

  createdAt           DateTime @default(now())

  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  liability VendorLiability @relation(fields: [vendorLiabilityId], references: [id])

  @@index([tenantId, vendorLiabilityId])
}

/// Vendor payment records.
model VendorPayment {
  id            Int      @id @default(autoincrement())
  tenantId      String   @db.Uuid
  paymentNo     String
  vendorId      Int

  paymentDate   DateTime
  amount        Decimal  @db.Decimal(12, 2)

  paymentMethod String   // BANK_TRANSFER | CHEQUE | CASH | ONLINE
  referenceNo   String?
  remarks       String?

  status        String   @default("DRAFT") // DRAFT | POSTED | VOID

  createdBy     Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant      Tenant                  @relation(fields: [tenantId], references: [id])
  vendor      Vendor                  @relation(fields: [vendorId], references: [id])
  allocations VendorPaymentAllocation[]

  @@unique([tenantId, paymentNo])
  @@index([tenantId, vendorId])
  @@index([tenantId, status])
}

/// Allocation of payment amounts to specific invoices.
model VendorPaymentAllocation {
  id            Int     @id @default(autoincrement())
  paymentId     Int
  invoiceId     Int
  amountApplied Decimal @db.Decimal(12, 2)

  payment VendorPayment        @relation(fields: [paymentId], references: [id])
  invoice LaundryVendorInvoice @relation(fields: [invoiceId], references: [id])

  @@unique([paymentId, invoiceId])
}

/// Append-only financial sub-ledger for vendor accounting.
/// Never update or delete rows. Balance = SUM(debit) - SUM(credit).
model VendorLedger {
  id              Int      @id @default(autoincrement())
  tenantId        String   @db.Uuid
  vendorId        Int

  transactionDate DateTime
  transactionType String   // INVOICE | PAYMENT | LIABILITY | RECOVERY_CREDIT | ADJUSTMENT | CREDIT_NOTE | OPENING_BALANCE

  referenceType   String   // INVOICE | PAYMENT | LIABILITY | CREDIT
  referenceId     Int

  debit           Decimal  @default(0) @db.Decimal(12, 2)
  credit          Decimal  @default(0) @db.Decimal(12, 2)

  remarks         String?

  createdAt       DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@index([tenantId, vendorId])
  @@index([tenantId, vendorId, transactionDate])
  @@index([tenantId, transactionType])
}

