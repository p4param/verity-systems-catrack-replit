  menus          CateringEventMenu[]
  healthScores   CateringEventHealthScore[]
  approvals      CateringEventApproval[]
  timeline       CateringEventTimeline[]
  customValues   CateringEventCustomFieldValue[]
  notifications  CateringEventNotification[]
  auditLogs      CateringEventAuditLog[]

  @@index([startDate])
  @@index([customerId])
  @@index([statusId])
  @@index([branchId])

  @@map("catering_events")
}

